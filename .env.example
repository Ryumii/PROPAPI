# Database (PostgreSQL + PostGIS)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=reapi
POSTGRES_USER=reapi
POSTGRES_PASSWORD=changeme_local_only
DATABASE_URL=postgresql+asyncpg://reapi:changeme_local_only@db:5432/reapi

# Redis
REDIS_URL=redis://redis:6379/0

# API (FastAPI)
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
API_DEBUG=true
API_SECRET_KEY=change-this-to-a-random-secret
CORS_ORIGINS=http://localhost:3000

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
WEB_PORT=3000

# External APIs
# SENTRY_DSN=
# STRIPE_SECRET_KEY=
# AZURE_STORAGE_CONNECTION_STRING=

# Logging
LOG_LEVEL=INFO
